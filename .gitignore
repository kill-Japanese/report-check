# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg

# 虚拟环境
venv/
env/
ENV/

# 数据文件（敏感，不提交根目录的）
users.json
sessions.json
rate_limit.json
# 【严重修复】只忽略根目录的协作数据.json，不忽略 data/ 下的
# 否则 push 失败后重新部署，协作数据会丢失（因为 data/ 不持久化）
./协作数据.json
audit.log
*.log
# data/ 目录用于持久化，会提交到 GitHub（除了会话和限流数据）
!data/
data/sessions.json
data/rate_limit.json
data/audit.log

# 上传文件
.uploads/

# 系统文件
.DS_Store
Thumbs.db
.deps_ok

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 临时文件
.trae/

# 生成的报表文件（报表HTML会提交，确保Render有数据）
项目延期点检表.xlsx
任务计划表_*.csv
超声波户表脚本_*.xls

# 【修复】忽略备份文件，避免大量垃圾文件进入git
*.xlsx.backup
*.xlsx.*_backup
*.xlsx.e2e_backup
*.xlsx.test_backup*
*.backup
*.py.backup

# TRAE 临时文件
.trae-html-share-packages/
